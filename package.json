{
  "name": "omnispider",
  "version": "1.0.0",
  "description": "All-in-one web spider orchestrator — 100% TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "omnispider": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "tsx src/cli.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "better-sqlite3": "^11.7.0",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "fastify": "^5.2.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.6.0",
    "playwright": "^1.49.0",
    "robots-parser": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
